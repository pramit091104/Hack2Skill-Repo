PORT=8000
NODE_ENV=development

# Google Cloud / Vertex AI Settings
GEMINI_API_KEY=your_gemini_api_key_here

# Firebase Admin Configuration
# EITHER provide FIREBASE_SERVICE_ACCOUNT_PATH (easier for local dev)
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json

# OR provide individual values (best for Cloud Run environments via Secret Manager)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-service-account-email@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour\nKey\nHere\n-----END PRIVATE KEY-----\n"

# Cloud Storage Bucket Name
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
